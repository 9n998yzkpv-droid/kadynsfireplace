# Copy to .env.local for local dev; set the same vars in the Vercel project.
# Never commit real values.

# --- Publisher (admin blog tool) -------------------------------------------
# Strong shared password for /publisher. Endpoint returns 503 if unset.
PUBLISHER_PASSWORD=

# GitHub token with contents:write on the repo below — the publisher writes
# posts as commits.
GITHUB_TOKEN=
GITHUB_REPO=9n998yzkpv-droid/kadynsfireplace

# --- Newsletter (Resend) ----------------------------------------------------
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Verified sender, e.g. "Kadyn <posts@yourdomain.com>"
NEWSLETTER_FROM=
# Random string (openssl rand -hex 32); signs confirmation links.
NEWSLETTER_SECRET=

# --- Site --------------------------------------------------------------------
# Canonical origin, e.g. https://example.com (used in emails and webhooks).
SITE_URL=

# --- n8n distribution (optional) ---------------------------------------------
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# --- Memberships (Supabase) --------------------------------------------------
# From the Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only master key — bypasses row-level security. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated E.164 phone allowlist for admin access (portfolio + Q&A tools).
ADMIN_PHONES=+17026864526
